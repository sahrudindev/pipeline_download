# Salin ke .env lalu sesuaikan
REDIS_URL=redis://redis:6379/0
DOWNLOAD_DIR=/app/downloads
FILE_TTL_SECONDS=1800
MAX_FILESIZE_MB=2048
RATE_LIMIT_PER_MIN=5
# (opsional) path file cookies Netscape untuk bypass anti-bot / video login
YTDLP_COOKIES=
# CORS: origin frontend
FRONTEND_ORIGIN=http://localhost:3000
